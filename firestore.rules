rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Primitives ---
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check: strictly look up role in users collection or check bootstrapped developer email
    function isAdminByEmail() {
      return isSignedIn() && 
             'email' in request.auth.token && 
             request.auth.token.email == 'andrewmanuel310@gmail.com';
    }

    function isAdmin() { 
      return isSignedIn() && (
        isAdminByEmail() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }

    // --- User Profiles ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.email is string && data.email.size() <= 200 &&
               data.role in ['user', 'admin'] &&
               data.createdAt is timestamp;
      }

      // Owner can read their document without needing recursive isAdmin check.
      // Any admin can read any profile.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      allow create: if isSignedIn() && 
                      request.auth.uid == userId &&
                      isValidUser(incoming()) && 
                      (incoming().role == 'user' || (incoming().role == 'admin' && isAdmin()));
                      
      allow update: if isSignedIn() && (
                      (request.auth.uid == userId && 
                       incoming().uid == existing().uid &&
                       incoming().email == existing().email &&
                       incoming().role == existing().role) ||
                      isAdmin()
                    );
      
      allow delete, list: if isAdmin();
    }

    // --- Operational Entries ---
    match /operational_entries/{entryId} {
      function isValidOperationalEntry(data) {
        return data.userId is string && data.userId.size() <= 128 &&
               data.employeeName is string && data.employeeName.size() <= 200 &&
               data.department is string && data.department.size() <= 100 &&
               data.contactNumber is string && data.contactNumber.size() <= 50 &&
               data.destination is string && data.destination.size() <= 300 &&
               data.purpose is string && data.purpose.size() <= 1000 &&
               data.scheduleDate is string && data.scheduleDate.size() <= 50 &&
               data.accountName is string && data.accountName.size() <= 200 &&
               (!('companyName' in data) || (data.companyName is string && data.companyName.size() <= 200)) &&
               (!('contactPerson' in data) || data.contactPerson is string) &&
               data.destinationType in ['Within Metro Manila', 'Outside Metro Manila'] &&
               data.outOfPocketExpense is number &&
               data.status in ['Draft', 'Ongoing', 'For Liquidation', 'Submitted', 'Approved', 'Rejected', 'Needs Revision', 'Completed'] &&
               (data.requestedCashAdvance == null || data.requestedCashAdvance is number) &&
               (!('cashAdvancePurpose' in data) || data.cashAdvancePurpose is string) &&
               (!('remarks' in data) || data.remarks is string) &&
               (!('adminNotes' in data) || data.adminNotes is string) &&
               (!('reimbursements' in data) || data.reimbursements is list) &&
               (!('liquidationItems' in data) || data.liquidationItems is list) &&
               (!('proofSlips' in data) || data.proofSlips is list) &&
               (!('reportDriveUrl' in data) || data.reportDriveUrl is string) &&
               (!('reportDriveId' in data) || data.reportDriveId is string);
      }

      // Security Pillar 8: Secure List Queries
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      isValidOperationalEntry(incoming()) &&
                      incoming().status in ['Draft', 'Ongoing', 'For Liquidation'] && 
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;

      allow update: if (
        isSignedIn() && (
          isAdmin() || (
            existing().userId == request.auth.uid &&
            isValidOperationalEntry(incoming()) &&
            incoming().updatedAt == request.time &&
            incoming().userId == existing().userId &&
            incoming().createdAt == existing().createdAt &&
            // Lock fields if terminal status or not in editable state
            (
              // Action: Edit Draft/Ongoing/Revision/Liquidation details
              (existing().status in ['Draft', 'Ongoing', 'Needs Revision', 'For Liquidation'] && 
               incoming().status in ['Draft', 'Ongoing', 'For Liquidation', 'Submitted']) ||
              
              // Action: Submit for Liquidation to Submitted
              (existing().status == 'For Liquidation' && 
               incoming().status == 'Submitted' &&
               incoming().diff(existing()).affectedKeys().hasAny(['reimbursements', 'liquidationItems', 'proofSlips', 'status', 'submittedAt', 'updatedAt', 'reportDriveUrl', 'reportDriveId']))
            )
          )
        )
      );

      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid && existing().status == 'Draft');
    }

    // --- Clients Registry ---
    match /clients/{clientId} {
      function isValidClient(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.name is string && data.name.size() <= 200;
      }
      allow read, list: if isSignedIn();
      allow create, update: if isAdmin() && isValidClient(incoming());
      allow delete: if isAdmin();
    }

    // --- Deleted System Clients ---
    match /deleted_system_clients/{clientId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
