# --- Google Drive Configuration ---
# 1. Personal Account Method (Recommended):
# Files are stored in the user's personal Drive. 
# Requires "Google Drive API" enabled in Cloud Console.

# 2. Service Account Method (Fallback):
# Files are stored in a Service Account's Drive (or shared folder).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# 3. Root Folder ID (Optional, works for both methods):
# If empty, starts from the root of the Drive (creates "STLAF" folder).
GOOGLE_DRIVE_PARENT_FOLDER_ID="1tVEMofd8dmPF-oP0FSBmEGTWBO7ypH_T"

# --- Firebase Configuration (Optional if using firebase-applet-config.json) ---
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_DATABASE_ID=
